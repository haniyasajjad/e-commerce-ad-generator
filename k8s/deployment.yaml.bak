# Base production deployment
# Includes:
# - Deployment
# - Service (LoadBalancer)
# - ConfigMap
# - HorizontalPodAutoscaler

apiVersion: apps/v1
kind: Deployment
metadata:
  name: ad-creative-api
  namespace: ad-creative
  labels:
    app: ad-creative-api
    version: v1
spec:
  replicas: 1
  selector:
    matchLabels:
      app: ad-creative-api
  template:
    metadata:
      labels:
        app: ad-creative-api
        version: v1
      annotations:
        prometheus.io/scrape: "true"
        prometheus.io/port: "8000"
        prometheus.io/path: "/metrics"
    spec:
      containers:
      - name: ad-creative
        image: 22i1081/ad-creative-api:latest
        ports:
        - containerPort: 8000
          name: http
        - containerPort: 8001
          name: metrics
        env:
        - name: MLFLOW_TRACKING_URI
          valueFrom:
            configMapKeyRef:
              name: ad-creative-config
              key: MLFLOW_TRACKING_URI
        - name: MODEL_PATH
          value: "/app/models/gemma-2-2b-it-Q5_K_M.gguf"
        resources:
          requests:
            memory: "1.5Gi"   # Safe scheduling on B2s
            cpu: "500m"
          limits:
            memory: "3.5Gi"   # Gives headroom for model load burst (B2s can burst)
            cpu: "2000m"
        livenessProbe:
          httpGet:
            path: /health
            port: 8000
          initialDelaySeconds: 60
          periodSeconds: 10
          timeoutSeconds: 5
          failureThreshold: 3
        readinessProbe:
          httpGet:
            path: /health
            port: 8000
          initialDelaySeconds: 30
          periodSeconds: 5
          timeoutSeconds: 3
          failureThreshold: 3
      imagePullSecrets:
      - name: dockerhub-secret

---
apiVersion: v1
kind: Service
metadata:
  name: ad-creative-service
  namespace: ad-creative
  labels:
    app: ad-creative-api
spec:
  type: LoadBalancer
  selector:
    app: ad-creative-api
  ports:
  - protocol: TCP
    port: 80
    targetPort: 8000
    name: http
  - protocol: TCP
    port: 8001
    targetPort: 8001
    name: metrics

---
apiVersion: v1
kind: ConfigMap
metadata:
  name: ad-creative-config
  namespace: ad-creative
data:
  MLFLOW_TRACKING_URI: "http://mlflow:5000"
  LOG_LEVEL: "INFO"
  MODEL_VERSION: "v1.0.0"

---
apiVersion: autoscaling/v2
kind: HorizontalPodAutoscaler
metadata:
  name: ad-creative-hpa
  namespace: ad-creative
spec:
  scaleTargetRef:
    apiVersion: apps/v1
    kind: Deployment
    name: ad-creative-api
  minReplicas: 2
  maxReplicas: 10
  metrics:
  - type: Resource
    resource:
      name: cpu
      target:
        type: Utilization
        averageUtilization: 70
  - type: Resource
    resource:
      name: memory
      target:
        type: Utilization
        averageUtilization: 80
  behavior:
    scaleDown:
      stabilizationWindowSeconds: 300
      policies:
      - type: Percent
        value: 50
        periodSeconds: 60
    scaleUp:
      stabilizationWindowSeconds: 0
      policies:
      - type: Percent
        value: 100
        periodSeconds: 30
      - type: Pods
        value: 2
        periodSeconds: 30
      selectPolicy: Max